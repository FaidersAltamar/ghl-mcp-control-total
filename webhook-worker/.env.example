# Token secreto para proteger el endpoint GET /webhooks/ghl (listar webhooks recientes)
GHL_WEBHOOK_ADMIN_SECRET=cambia-esto-por-un-token-seguro

# Ruta del webhook (debe coincidir con lo configurado en GHL Marketplace)
GHL_WEBHOOK_PATH=/webhooks/ghl

# Máximo de webhooks almacenados en memoria
GHL_WEBHOOK_MAX_STORED=100
